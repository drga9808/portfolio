---
import SectionWrapper from "./SectionWrapper.astro";
import { config } from "../data/config";
---

<SectionWrapper id="skills" heading="Skills">
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
    {
      config.skills.map((group) => (
        <div>
          <h3 class="text-sm font-semibold text-accent-light uppercase tracking-wider mb-3">
            {group.category}
          </h3>
          <div class="flex flex-wrap gap-2">
            {group.items.map((item) => (
              <span class="px-3 py-1.5 text-sm rounded-lg bg-surface border border-border text-text">
                {item}
              </span>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</SectionWrapper>
