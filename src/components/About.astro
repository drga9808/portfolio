---
import SectionWrapper from "./SectionWrapper.astro";
import { config } from "../data/config";
---

<SectionWrapper id="about" heading="About">
  <div class="flex flex-col md:flex-row gap-10 items-start">
    <div class="space-y-4 text-muted leading-relaxed flex-1">
      {config.about.paragraphs.map((p) => <p>{p}</p>)}
    </div>
    <img
      src={`${import.meta.env.BASE_URL}profile.jpg`}
      alt={config.name}
      loading="lazy"
      class="w-56 h-56 rounded-xl object-cover border-2 border-border shrink-0"
    />
  </div>
</SectionWrapper>
