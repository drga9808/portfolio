---
interface Props {
  id: string;
  heading: string;
  centered?: boolean;
}

const { id, heading, centered = false } = Astro.props;
---

<section id={id} class:list={["py-20 px-6 max-w-5xl mx-auto", centered && "text-center"]}>
  <h2 class="text-3xl font-bold mb-12 gradient-text inline-block">{heading}</h2>
  <slot />
</section>
