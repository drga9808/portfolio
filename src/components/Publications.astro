---
import SectionWrapper from "./SectionWrapper.astro";
import { config } from "../data/config";
---

<SectionWrapper id="publications" heading="Publications">
  <div class="space-y-6">
    {
      config.publications.map((pub) => (
        <a
          href={pub.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${pub.title} (opens in new tab)`}
          class="block bg-surface border border-border rounded-xl p-6 card-glow transition-all hover:border-accent/30"
        >
          <h3 class="text-base font-semibold text-text">
            {pub.title}
          </h3>
          <p class="text-sm text-accent-light mt-1">
            {pub.publisher} &middot; {pub.date}
          </p>
          {pub.context && (
            <p class="text-xs text-accent-light/70 mt-1">{pub.context}</p>
          )}
          <p class="text-sm text-muted mt-3 leading-relaxed">{pub.abstract}</p>
        </a>
      ))
    }
  </div>
</SectionWrapper>
