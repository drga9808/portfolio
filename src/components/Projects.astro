---
import SectionWrapper from "./SectionWrapper.astro";
import { config } from "../data/config";

const base = import.meta.env.BASE_URL;
---

<SectionWrapper id="projects" heading="Projects">
  <div class="grid md:grid-cols-2 gap-4">
    {
      config.projects.map((project) => (
        <a
          href={`${base}/projects/${project.slug}/`}
          class="bg-surface border border-border rounded-xl p-4 transition-all card-glow hover:border-accent/30 block"
        >
          <h3 class="text-base font-semibold text-text mb-2">{project.title}</h3>
          <p class="text-muted text-sm mb-3 leading-relaxed line-clamp-2">
            {project.description}
          </p>
          <div class="flex flex-wrap gap-1.5">
            {project.tech.map((t) => (
              <span class="px-2 py-0.5 text-xs rounded-md bg-accent/10 text-accent-light font-medium">
                {t}
              </span>
            ))}
          </div>
        </a>
      ))
    }
  </div>
</SectionWrapper>
