---
import SectionWrapper from "./SectionWrapper.astro";
import { config } from "../data/config";
---

<SectionWrapper id="education" heading="Education">
  <div class="relative border-l-2 border-border pl-8 space-y-8">
    {
      config.education.map((edu) => (
        <div class="relative">
          <div class="absolute -left-[2.56rem] top-1.5 w-3 h-3 rounded-full bg-accent border-2 border-bg" />
          <h3 class="text-base font-semibold text-text">{edu.degree}</h3>
          <p class="text-sm text-accent-light">{edu.school}</p>
          <p class="text-xs text-muted mt-0.5">{edu.year}</p>
        </div>
      ))
    }
  </div>
</SectionWrapper>
