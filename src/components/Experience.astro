---
import SectionWrapper from "./SectionWrapper.astro";
import { config } from "../data/config";
---

<SectionWrapper id="experience" heading="Experience">
  <div class="relative border-l-2 border-border pl-8 space-y-12">
    {
      config.experience.map((exp) => (
        <div class="relative">
          <div class="absolute -left-[2.56rem] top-1.5 w-3 h-3 rounded-full bg-accent border-2 border-bg" />
          <div class="mb-1">
            <h3 class="text-lg font-semibold text-text">{exp.role}</h3>
            <p class="text-sm text-accent-light">{exp.company}</p>
            <p class="text-xs text-muted mt-0.5">{exp.period}</p>
          </div>
          <ul class="mt-3 space-y-2">
            {exp.bullets.map((b) => (
              <li class="text-sm text-muted leading-relaxed flex gap-2">
                <span class="text-accent mt-1 shrink-0">-</span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</SectionWrapper>
